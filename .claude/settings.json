{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-level Claude Code settings. Adjust to your team's comfort level. Higher trust = less prompting.",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(python3 -m http.server *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ls *)"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)"
    ],
    "deny": []
  }
}
