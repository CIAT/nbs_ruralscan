# Schema JSON is generated from the CSV source of truth — never hand-edit.
# Run `python3 src/nbs_ruralscan/schema_tools/generate.py schema` after editing a CSV.
# `linguist-generated` collapses these in GitHub diffs and labels them "generated".
schema/*.json                  linguist-generated=true
schema/recipes/**/*.json       linguist-generated=true
schema/registers/*.json        linguist-generated=true

# The column manifest is hand-authored, not generated — keep it visible in diffs.
schema/structure/columns.json  -linguist-generated

# Force LF on ALL CSVs cross-platform. The registers/recipes hold multiline quoted
# fields (185+ EV rows have embedded newlines); on Windows, git autocrlf would rewrite
# those embedded LFs to CRLF on checkout, producing ragged rows that crash the
# QA "Apply decisions & rebuild" path with `dict contains fields not in fieldnames: None`
# (issue #104). `text eol=lf` pins them to LF so the registers read identically everywhere.
*.csv                          text eol=lf
